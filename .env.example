# ============================================================================
# ParcInfo v2.5.0 — Docker Environment Configuration
# ============================================================================
#
# INSTRUCTIONS:
# 1. Copier ce fichier en ".env" dans le répertoire du projet
# 2. Adapter les valeurs selon votre environnement
# 3. Référencer via: docker-compose -f docker-compose.yml --env-file .env up
#
# NOTE: Les valeurs par défaut dans docker-compose.yml s'appliquent si
#       .env n'existe pas. Ce fichier est OPTIONNEL.

# ============================================================================
# FLASK — Application Core
# ============================================================================

# Mode exécution
FLASK_ENV=production                    # development | production
FLASK_APP=app.py

# Port interne du conteneur (ne pas changer sauf config avancée)
FLASK_PORT=5000

# Clé secrète (auto-générée si absent, recommandé de ne pas changer)
# SECRET_KEY=votre-clé-256-bits-base64

# ============================================================================
# SYSTÈME & PYTHON
# ============================================================================

# Buffering stdout (1 = ligne par ligne, important pour logs)
PYTHONUNBUFFERED=1

# Timezone du conteneur
TZ=Europe/Paris                         # Europe/Paris | Europe/Brussels | UTC | etc

# ============================================================================
# BASE DE DONNÉES
# ============================================================================

# Type de BD (SQLite local ou Turso cloud - future v2.6)
DATABASE_TYPE=sqlite                    # sqlite | turso
DATABASE_URL=sqlite:///app/parc_info.db # Chemin BD locale

# Turso (optionnel, pour future versions)
# TURSO_API_KEY=xxx
# TURSO_ORG=xxx

# ============================================================================
# SÉCURITÉ
# ============================================================================

# Rate limiting authentification (10 tentatives par 5 min)
RATE_LIMIT_LOGIN=10                     # Tentatives max
RATE_LIMIT_WINDOW=300                   # Secondes (5 min)

# Timeout session
SESSION_TIMEOUT_HOURS=8

# HTTPS (pour reverse proxy / production)
# SCHEME=https                           # http | https (pour reverse proxy)

# ============================================================================
# CACHE
# ============================================================================

# TTL cache en secondes
CACHE_TTL=300                           # 5 minutes (défaut)
# CACHE_TTL=600                         # 10 minutes (si plus de données)

# ============================================================================
# COMPRESSION
# ============================================================================

# Compression réseau (Brotli/Gzip)
COMPRESSION_LEVEL=6                     # 1-11 (6 = défaut, bon ratio)
COMPRESSION_ENABLED=true

# ============================================================================
# RECHERCHE & AUTOCOMPLETE
# ============================================================================

# Limite résultats recherche
SEARCH_LIMIT=20                         # Résultats max affichés
AUTOCOMPLETE_LIMIT=10                   # Suggestions max

# ============================================================================
# UPLOADS & FICHIERS
# ============================================================================

# Taille max fichier upload (en MB)
MAX_UPLOAD_SIZE_MB=50

# Types fichiers autorisés (comma-separated)
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,docx,xlsx,txt,zip

# ============================================================================
# AUDIT & LOGGING
# ============================================================================

# Historique max lignes avant nettoyage auto
AUDIT_MAX_ENTRIES=500                   # Auto-cleanup au-delà

# Niveau logging (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# ============================================================================
# DOCKER / RESSOURCES
# ============================================================================

# Limites CPU (utilisé par docker-compose)
DOCKER_CPU_LIMIT=2                      # Nombre de cores (2 = défaut)
DOCKER_CPU_RESERVE=0.5                  # Cores minimum

# Limites Mémoire (utilisé par docker-compose)
DOCKER_MEMORY_LIMIT=512m                # RAM max
DOCKER_MEMORY_RESERVE=256m              # RAM minimum

# Politique redémarrage
DOCKER_RESTART_POLICY=unless-stopped    # no | always | unless-stopped | on-failure

# ============================================================================
# VOLUMES DOCKER (chemins sur NAS)
# ============================================================================

# Dossier de base sur NAS
DOCKER_DATA_PATH=/volume1/docker/parcinfo

# Sous-dossiers (relatif à DOCKER_DATA_PATH)
VOLUME_DB_PATH=/data                    # Base de données
VOLUME_UPLOADS_PATH=/data/uploads       # Documents joints
VOLUME_BACKUPS_PATH=/data/backups       # Backups
VOLUME_CONFIG_PATH=/data/config         # Configuration persistée

# ============================================================================
# FEATURES OPTIONNELLES (v2.5.0+)
# ============================================================================

# Chiffrement credentials (v2.5.0)
ENCRYPTION_ENABLED=true                 # true | false

# Full-text search (v2.5.0)
SEARCH_ENABLED=true

# Autocomplete dynamique (v2.5.0)
AUTOCOMPLETE_ENABLED=true

# Indexation BD (v2.5.0)
DATABASE_INDEXING=true

# ============================================================================
# NOTIFICATION & ALERTES (Future v2.6)
# ============================================================================

# Email notifications (non implémenté v2.5.0)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=votre-email@gmail.com
# SMTP_PASSWORD=votre-mdp-app
# NOTIFICATION_ENABLED=false

# ============================================================================
# ADMIN & MONITORING (Future v2.6)
# ============================================================================

# URL de monitoring externe
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ============================================================================
# EXEMPLES DE CONFIGURATION
# ============================================================================

# --- Config Légère (NAS petit) ---
# DOCKER_CPU_LIMIT=1
# DOCKER_MEMORY_LIMIT=256m
# CACHE_TTL=180
# COMPRESSION_LEVEL=4

# --- Config Standard (NAS moyen) ---
# DOCKER_CPU_LIMIT=2
# DOCKER_MEMORY_LIMIT=512m
# CACHE_TTL=300
# COMPRESSION_LEVEL=6
# (C'est la config par défaut)

# --- Config Lourde (NAS puissant + beaucoup de données) ---
# DOCKER_CPU_LIMIT=4
# DOCKER_MEMORY_LIMIT=1024m
# CACHE_TTL=600
# COMPRESSION_LEVEL=8
# AUDIT_MAX_ENTRIES=1000

# ============================================================================
# NOTES IMPORTANTES
# ============================================================================
#
# 1. Ce fichier est OPTIONNEL — les valeurs par défaut s'appliquent sinon
#
# 2. Ne pas commettre .env en Git (ajouter à .gitignore)
#
# 3. Pour appliquer changements :
#    docker-compose down
#    docker-compose up -d
#
# 4. Secrets sensibles (clés API, passwords) → utiliser Docker Secrets
#    en production, pas .env
#
# 5. Format : KEY=value (pas de guillemets sauf si valeur contient espaces)
#
# 6. Commentaires : ligne commençant par #
#
# ============================================================================
