# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=False
SECRET_KEY=your-secret-key-here-change-this-to-a-random-value
FLASK_PORT=5000

# Database
DATABASE_URL=sqlite:///parc_info.db
# Optional: For Turso serverless database instead of SQLite
# DATABASE_TYPE=turso
# TURSO_URL=libsql://your-database-url.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# File Uploads
MAX_FILE_SIZE_MB=50
UPLOAD_FOLDER=uploads

# Security
SESSION_TIMEOUT_HOURS=8
RATE_LIMIT_ATTEMPTS=10
RATE_LIMIT_WINDOW_MINUTES=5

# Optional: Logging
# LOG_LEVEL=INFO
# LOG_FILE=parcinfo.log
